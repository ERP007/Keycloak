KEYCLOAK_CONTAINER_NAME=erp007-keycloak
KEYCLOAK_HOST_PORT=9001
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

# Public auth domain routed through Cloudflare Tunnel.
KEYCLOAK_HOSTNAME=https://auth.erp007.xyz
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_START_MODE=start
KEYCLOAK_THEME_STATIC_MAX_AGE=-1
KEYCLOAK_THEME_CACHE_THEMES=false
KEYCLOAK_THEME_CACHE_TEMPLATES=false

POSTGRES_CONTAINER_NAME=erp007-keycloak-postgres
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change-me-postgres-password
